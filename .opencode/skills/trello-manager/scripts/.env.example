# Trello API Credentials
# Get your API key and token from: https://trello.com/power-ups/admin
# 
# 1. Create a new Power-Up or select an existing one
# 2. Copy your API Key
# 3. Click "Token" link to generate a token with read/write access
# 
# WARNING: Never commit this file with actual credentials!

TRELLO_API_KEY=your_api_key_here
TRELLO_API_TOKEN=your_token_here
